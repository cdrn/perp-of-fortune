{
  "name": "permanent-underpod",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "An AI rolls a random perp on Hyperliquid and we watch it drown. Live tracker + Underwater-o-meter dashboard. Keys held by sigil — the agent can trade but physically cannot withdraw.",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/main.ts",
    "start": "tsx --env-file=.env src/main.ts",
    "typecheck": "tsc --noEmit",
    "hl": "tsx scripts/hl.ts",
    "close": "tsx --env-file=.env scripts/close.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@msgpack/msgpack": "^3.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "js-sha3": "^0.9.3",
    "typescript": "^5.7.3"
  }
}
